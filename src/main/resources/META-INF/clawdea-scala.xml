<!--
  Optional descriptor — loaded by IntelliJ only when org.intellij.scala is
  installed. Declared via the optional <depends> in plugin.xml. When the Scala
  plugin is absent this file is not applied, so consumers' getService lookup
  returns null (or throws) and they degrade to the no-Scala-plugin path.
-->
<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceInterface="com.adobe.clawdea.language.scala.ScalaPsiBridge"
            serviceImplementation="com.adobe.clawdea.language.scala.ScalaPluginPsiBridge"/>
    </extensions>
</idea-plugin>
